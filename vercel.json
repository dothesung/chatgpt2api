{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/main.py"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/main.py"
    },
    {
      "source": "/docs",
      "destination": "/main.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/web/$1"
    }
  ]
}
